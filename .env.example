COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_API_SECRET=your_coinbase_api_secret_here
ANTHROPIC_API_KEY=sk-ant-...
# Comma-separated list of trading pairs
PRODUCT_IDS=BTC-USD,ETH-USD,SOL-USD,DOGE-USD,ADA-USD,AVAX-USD
# Maximum USD Claude is allowed to commit in a single trade decision
MAX_TRADE_AMOUNT_USD=100.00
# How often (in seconds) to run a full trading cycle (default: 3600 = 1 hour)
CYCLE_INTERVAL_SECONDS=3600
# Todoist API token for credit error notifications (optional)
TODOIST_API_TOKEN=your_todoist_api_token_here
